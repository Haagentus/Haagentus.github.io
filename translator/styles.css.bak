.preview-shell {
    min-height: calc(100vh - 150px);
    padding: 110px 16px 36px;
}

.preview-main {
    width: min(1180px, 100%);
    margin: 0 auto;
}

.page-kicker {
    margin: 0 0 10px;
    color: #d5aa4c;
    font: 700 12px/1 Montserrat, "Helvetica Neue", Helvetica, Arial, sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.page-title {
    margin-bottom: 16px;
    font-size: clamp(34px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: 0;
    text-transform: none;
}

.page-lead {
    max-width: 760px;
    color: rgba(255, 255, 255, .82);
}

.preview-workspace {
    display: grid;
    grid-template-columns: minmax(280px, 420px) minmax(0, 1fr);
    gap: 18px;
    margin-top: 30px;
}

.tool-panel,
.render-panel {
    border: 1px solid rgba(255, 255, 255, .13);
    background: rgba(0, 0, 0, .44);
    box-shadow: 0 18px 42px rgba(0, 0, 0, .24);
}

.tool-panel {
    padding: 18px;
}

.panel-block + .panel-block {
    margin-top: 18px;
}

.control-label {
    display: block;
    margin-bottom: 8px;
    color: rgba(255, 255, 255, .78);
    font: 700 12px/1.3 Montserrat, "Helvetica Neue", Helvetica, Arial, sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.preview-textarea,
.control-select {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 4px;
    color: #fff;
    background: rgba(0, 0, 0, .42);
    outline: 0;
}

.preview-textarea {
    min-height: 210px;
    resize: vertical;
    padding: 14px;
    font-size: 18px;
    line-height: 1.6;
}

.control-select {
    height: 44px;
    padding: 0 12px;
}

.preview-textarea:focus,
.control-select:focus,
.range-control input:focus {
    border-color: #d5aa4c;
    box-shadow: 0 0 0 2px rgba(213, 170, 76, .18);
}

.example-list,
.align-toggle {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.chip-button,
.icon-button {
    min-height: 36px;
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 4px;
    color: rgba(255, 255, 255, .86);
    background: rgba(255, 255, 255, .06);
}

.chip-button {
    padding: 0 12px;
}

.icon-button {
    width: 40px;
    font-weight: 700;
}

.chip-button:hover,
.chip-button:focus,
.icon-button:hover,
.icon-button:focus,
.icon-button.is-active {
    border-color: #d5aa4c;
    color: #fff;
    background: rgba(213, 170, 76, .18);
}

.range-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}

.range-control input {
    width: 100%;
    accent-color: #d5aa4c;
}

.range-value {
    float: right;
    color: rgba(255, 255, 255, .66);
    font-weight: 400;
}

.render-panel {
    display: flex;
    min-height: 560px;
    flex-direction: column;
}

.render-meta {
    display: grid;
    gap: 14px;
    padding: 16px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, .12);
}

.render-heading {
    min-width: 0;
}

.render-meta h2 {
    margin: 0 0 4px;
    font-size: 18px;
    letter-spacing: 0;
    line-height: 1.25;
    text-transform: none;
}

.render-meta p {
    margin: 0;
    color: rgba(255, 255, 255, .62);
    font-size: 14px;
}

.font-control-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(140px, 1fr));
    gap: 10px;
}

.font-control-grid .control-label {
    margin-bottom: 6px;
}

.download-link {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    padding: 0 14px;
    border: 1px solid #219ab3;
    border-radius: 4px;
    color: #9ee8f5;
    font-family: Montserrat, "Helvetica Neue", Helvetica, Arial, sans-serif;
    text-transform: uppercase;
}

.render-font-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
}

.image-save-button {
    background: transparent;
}

.download-link:hover,
.download-link:focus {
    color: #001014;
    background: #219ab3;
    text-decoration: none;
}

.download-link:disabled {
    cursor: wait;
    opacity: .62;
}

.preview-stage {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 14px;
    padding: clamp(18px, 5vw, 56px);
}

.preview-output {
    width: 100%;
    min-height: 320px;
    padding: clamp(18px, 4vw, 42px);
    border: 1px solid rgba(255, 255, 255, .12);
    background:
        linear-gradient(135deg, rgba(255, 255, 255, .07), rgba(255, 255, 255, .01)),
        rgba(255, 255, 255, .04);
    white-space: pre-wrap;
    word-break: break-word;
}

@media (max-width: 860px) {
    .preview-shell {
        padding-top: 82px;
    }

    .preview-workspace {
        grid-template-columns: 1fr;
    }

    .render-panel {
        min-height: 420px;
    }

    .render-font-row {
        align-items: flex-start;
    }
}

@media (max-width: 560px) {
    .range-grid {
        display: block;
    }

    .font-control-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .range-control + .range-control {
        margin-top: 12px;
    }

    .preview-stage .download-link {
        width: 100%;
    }
}
